---
import "leaflet/dist/leaflet.css";
import "../styles/global.css";
import { mapPlaces, mapSize, mapZones } from "../data/map";

const mapPayload = { mapPlaces, mapSize, mapZones };
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Mapa politico interactivo de Thalasia con marcadores de lore." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mapa de Thalasia | Atlas de Campaña</title>
  </head>
  <body class="map-body">
    <header class="site-header" aria-label="Navegacion principal">
      <a class="brand" href="/">Thalasia</a>
      <nav class="nav-links">
        <a href="/">Inicio</a>
        <a href="/mapa">Mapa</a>
        <a href="/entradas">Entradas</a>
      </nav>
    </header>

    <main class="map-shell">
      <aside class="map-sidebar" aria-label="Controles del mapa">
        <button class="map-layer-toggle active" type="button" data-layer="lore" aria-pressed="true">
          <span>Paises</span>
          <span class="dot countries"></span>
        </button>
        <button class="map-layer-toggle map-layer-toggle-zones active" type="button" data-layer="zones" aria-pressed="true">
          <span>Zonas</span>
          <span class="dot zones"></span>
        </button>
      </aside>

      <section class="map-stage" aria-label="Mapa interactivo de Thalasia">
        <div id="thalasia-map"></div>
      </section>
    </main>

    <script id="map-data" type="application/json" is:inline set:html={JSON.stringify(mapPayload)}></script>
    <script>
      import L from "leaflet";

      type MapPlace = {
        id: string;
        name: string;
        kind: string;
        x: number;
        y: number;
        summary: string;
        href?: string;
      };
      type MapPayload = {
        mapPlaces: MapPlace[];
        mapZones: MapPlace[];
        mapSize: {
          width: number;
          height: number;
        };
      };

      const dataElement = document.getElementById("map-data") as HTMLScriptElement | null;
      const { mapPlaces, mapSize, mapZones } = JSON.parse(dataElement?.textContent ?? "{}") as MapPayload;
      const bounds = [
        [0, 0],
        [mapSize.height, mapSize.width],
      ] as L.LatLngBoundsExpression;

      const map = L.map("thalasia-map", {
        attributionControl: false,
        crs: L.CRS.Simple,
        maxBounds: bounds,
        maxBoundsViscosity: 0.85,
        minZoom: -2,
        maxZoom: 2,
        zoomSnap: 0.25,
      });

      L.imageOverlay("/images/thalasia-political-map.png", bounds).addTo(map);
      map.fitBounds(bounds);

      const countryLayer = L.layerGroup().addTo(map);
      const zoneLayer = L.layerGroup().addTo(map);

      function createIcon(className: string, size: number) {
        return L.divIcon({
          className: `map-pin ${className}`,
          html: "<span></span>",
          iconSize: [size, size],
          iconAnchor: [size / 2, size / 2],
          popupAnchor: [0, -(size / 2)],
        });
      }

      function addMarkers(items: MapPlace[], layer: L.LayerGroup, className: string, size: number) {
        items.forEach((place) => {
        const marker = L.marker([mapSize.height - place.y, place.x], {
          icon: createIcon(className, size),
          title: place.name,
        });

        marker.bindTooltip(place.name, {
          direction: "top",
          offset: [0, -(size / 2)],
          opacity: 0.95,
        });

        marker.on("click", () => {
          if (place.href) {
            window.location.href = place.href;
          }
        });
          marker.addTo(layer);
        });
      }

      addMarkers(mapPlaces, countryLayer, "map-pin-country", 24);
      addMarkers(mapZones, zoneLayer, "map-pin-zone", 18);

      const loreToggle = document.querySelector("[data-layer='lore']") as HTMLButtonElement | null;
      const zonesToggle = document.querySelector("[data-layer='zones']") as HTMLButtonElement | null;

      function bindToggle(button: HTMLButtonElement | null, layer: L.LayerGroup) {
        button?.addEventListener("click", () => {
        const isVisible = map.hasLayer(layer);
        if (isVisible) {
          map.removeLayer(layer);
          button.classList.remove("active");
          button.setAttribute("aria-pressed", "false");
        } else {
          layer.addTo(map);
          button.classList.add("active");
          button.setAttribute("aria-pressed", "true");
        }
      });
      }

      bindToggle(loreToggle, countryLayer);
      bindToggle(zonesToggle, zoneLayer);
    </script>
  </body>
</html>
